            </div>
            
            <div class="file-tree">
                <div class="file-tree-title">📁 Microservice Files (<span id="file-source">Local + GitHub</span>)</div>
                <div id="file-list">Loading...</div>
            </div>
            
            <div class="tool-section">
                <button class="tool-button" onclick="refreshFiles()">🔄 Refresh Files</button>
                <div class="tool-description">Reload all files from local + GitHub</div>
            </div>
            
