                    <button class="btn btn-warning" onclick="commitToGithub()" id="commit-btn" style="display:none;">📤 Push to GitHub</button>
                    <button class="btn btn-danger" onclick="reloadFile()">↻ Reload</button>
                </div>
            </div>
            <div id="monaco-editor"></div>
        </div>
        
        <div class="command-line">
            <div class="command-header">> COMMAND LINE</div>
            <div class="command-content" id="terminal">$ SDOS Developer Workspace - Persistent GitHub Storage
$ Monaco Editor (VS Code) initialized
$ Repositories are saved and persist across restarts
$ </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs/loader.min.js"></script>
    <script>
        let editor;
        let currentFile = '';
        let currentFilePath = '';
        let currentSource = 'local';
        let currentRepo = '';
        let currentSha = '';
        let githubRepos = [];
        
        require.config({ paths: { vs: 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs' }});
        
        require(['vs/editor/editor.main'], function() {
            editor = monaco.editor.create(document.getElementById('monaco-editor'), {
                value: '# SDOS Developer Workspace - Persistent Multi-Repository Editor\\n# \\n# Features:\\n#   - Add multiple GitHub repositories\\n#   - Repositories persist across restarts\\n#   - View all microservices in one place\\n#   - Edit and push changes to GitHub\\n#   - Local file editing\\n# \\n# Getting Started:\\n#   1. Click "+ Add Repository" to connect GitHub repos\\n#   2. Files from all repos appear in the file list\\n#   3. Edit and push changes back to GitHub\\n#   4. Your repos are saved automatically\\n',
                language: 'python',
                theme: 'vs-dark',
                automaticLayout: true,
                fontSize: 14,
                minimap: { enabled: true },
                scrollBeyondLastLine: false,
                wordWrap: 'on'
            });
            
            addTerminalLine('VS Code Monaco Editor initialized');
            addTerminalLine('Loading saved GitHub repositories...');
            loadGithubRepos();
            loadFileList();
        });
        
        function showGithubModal() {
            document.getElementById('github-modal').classList.add('active');
        }
        
        function closeModal() {
            document.getElementById('github-modal').classList.remove('active');
        }
        
        async function loadGithubRepos() {
            const response = await fetch('/api/list-github-repos');
            const data = await response.json();
            
            githubRepos = data.repos || [];
            updateReposList();
            
            if (githubRepos.length > 0) {
                addTerminalLine(`Loaded ${githubRepos.length} saved repositories`);
            } else {
                addTerminalLine('No saved repositories found');
            }
        }
        
        function updateReposList() {
            const container = document.getElementById('github-repos-list');
            
            if (githubRepos.length === 0) {
                container.innerHTML = '<p style="color: #64748b;">No repositories connected</p>';
            } else {
                container.innerHTML = '';
                githubRepos.forEach((repo, idx) => {
                    const div = document.createElement('div');
                    div.className = 'repo-item';
                    div.innerHTML = `
                        <span class="repo-name">${repo}</span>
                        <button class="btn btn-danger btn-small" onclick="removeRepo(${idx})">Remove</button>
                    `;
                    container.appendChild(div);
                });
            }
        }
        
        async function removeRepo(index) {
            const response = await fetch('/api/remove-github-repo', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ index: index })
            });
            
            const data = await response.json();
            if (data.success) {
                await loadGithubRepos();
                await loadFileList();
                addTerminalLine(`Removed repository`);
            }
        }
        
        async function connectGithub() {
            const token = document.getElementById('github-token').value;
            const owner = document.getElementById('github-owner').value;
            const repo = document.getElementById('github-repo').value;
            
            if (!token || !owner || !repo) {
                addTerminalLine('✗ Please fill in all fields');
                return;
            }
            
            const response = await fetch('/api/add-github-repo', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token, owner, repo })
            });
            
            const data = await response.json();
            
            if (data.success) {
                closeModal();
                document.getElementById('github-token').value = '';
                document.getElementById('github-owner').value = '';
                document.getElementById('github-repo').value = '';
                
                await loadGithubRepos();
                await loadFileList();
                addTerminalLine(`✓ Added and saved repository: ${owner}/${repo}`);
            } else {
                addTerminalLine(`✗ Failed to add repository: ${data.error}`);
            }
        }
        
        function openVSCode() {
            addTerminalLine('Visual Studio Code (Monaco Editor) is active');
            editor.focus();
        }
        
        async function loadFileList() {
            try {
                const response = await fetch('/api/list-all-files');
                const data = await response.json();
                
                const fileList = document.getElementById('file-list');
                fileList.innerHTML = '';
                
                if (data.error) {
                    fileList.innerHTML = `<div style="color: #ef4444;">${data.error}</div>`;
                    return;
                }
                
                if (data.files && data.files.length > 0) {
                    data.files.forEach(file => {
                        const div = document.createElement('div');
                        div.className = 'file-item';
                        
                        const repoLabel = file.repo 
                            ? ` <span class="file-repo" style="color:#22c55e;">[GitHub: ${file.repo}]</span>` 
                            : ` <span class="file-repo" style="color:#94a3b8;">[Local]</span>`;
                        div.innerHTML = `${file.name}${repoLabel}`;
                        
                        div.onclick = () => loadFile(
                            file.path, 
                            file.name, 
                            file.type || 'github',
                            file.repo || '',
                            file.sha || ''
                        );
                        fileList.appendChild(div);
                    });
                    
                    const githubCount = data.files.filter(f => f.repo).length;
                    const localCount = data.files.length - githubCount;
                    addTerminalLine(`Found ${data.files.length} files (${localCount} local, ${githubCount} GitHub)`);
                } else {
                    fileList.innerHTML = '<div style="color: #94a3b8;">No files found</div>';
                }
            } catch (error) {
                addTerminalLine(`Error loading files: ${error.message}`);
            }
        }
        
        async function loadFile(filepath, filename, source, repo, sha = '') {
            try {
                const response = await fetch('/api/load-file', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ filepath, source, repo })
                });
                const data = await response.json();
                
                if (data.content) {
                    editor.setValue(data.content);
                    currentFile = filename;
                    currentFilePath = filepath;
                    currentSource = source;
                    currentRepo = repo;
                    currentSha = data.sha || sha;
                    document.getElementById('current-file').textContent = repo ? `${filename} [${repo}]` : filename;
                    
                    if (source === 'github') {
                        document.getElementById('commit-btn').style.display = 'inline-block';
                    } else {
                        document.getElementById('commit-btn').style.display = 'none';
                    }
                    
                    const ext = filename.split('.').pop();
                    const langMap = {
                        'py': 'python', 'js': 'javascript', 'html': 'html', 'css': 'css',
                        'json': 'json', 'yaml': 'yaml', 'yml': 'yaml', 'sh': 'shell'
                    };
                    monaco.editor.setModelLanguage(editor.getModel(), langMap[ext] || 'plaintext');
                    
                    document.querySelectorAll('.file-item').forEach(item => {
                        item.classList.remove('active');
                    });
                    event.target.classList.add('active');
                    
                    addTerminalLine(`Loaded ${filename} from ${source} (${data.content.split('\\n').length} lines)`);
                    editor.focus();
                } else {
                    addTerminalLine(`Error: ${data.error}`);
                }
            } catch (error) {
                addTerminalLine(`Error: ${error.message}`);
            }
        }
        
        async function saveFile() {
            if (!currentFilePath) {
                addTerminalLine('No file selected');
                return;
            }
            
            const content = editor.getValue();
            
            try {
                const response = await fetch('/api/save-file', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        filepath: currentFilePath,
                        content: content,
                        source: currentSource,
                        repo: currentRepo,
                        sha: currentSha
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    if (data.sha) {
                        currentSha = data.sha;
                    }
                    addTerminalLine(`✓ Saved ${currentFile}`);
                } else {
                    addTerminalLine(`✗ Error: ${data.error}`);
                }
            } catch (error) {
                addTerminalLine(`✗ Error: ${error.message}`);
            }
        }
        
        async function commitToGithub() {
            await saveFile();
            addTerminalLine(`✓ Pushed ${currentFile} to ${currentRepo}`);
        }
        
        function reloadFile() {
            if (currentFilePath) {
                loadFile(currentFilePath, currentFile, currentSource, currentRepo, currentSha);
            }
        }
        
        function refreshFiles() {
            loadFileList();
        }
        
        function goToDashboard() {
            window.location.href = 'http://localhost:8080';
        }
        
        function checkPipelines() {
            fetch('http://localhost:7000')
                .then(() => window.location.href = 'http://localhost:7000')
                .catch(() => addTerminalLine('✗ Pipeline Dashboard not running'));
        }
        
        function addTerminalLine(text) {
            const terminal = document.getElementById('terminal');
            terminal.innerHTML += '$ ' + text + '<br>';
            terminal.scrollTop = terminal.scrollHeight;
        }
    </script>
</body>
</html>
'''

@app.route('/')
def workspace():
    return render_template_string(WORKSPACE_TEMPLATE)

@app.route('/api/list-github-repos')
def list_github_repos():
    """List connected GitHub repos from file"""
    repos = load_repos_from_file()
    repo_names = [f"{r['owner']}/{r['repo']}" for r in repos]
    return jsonify({'repos': repo_names})

@app.route('/api/add-github-repo', methods=['POST'])
def add_github_repo():
    """Add GitHub repository and save to file"""
    data = request.json
    token = data.get('token', '')
    owner = data.get('owner', '')
    repo = data.get('repo', '')
    
    # Test connection
    result = get_github_files(token, owner, repo)
    
    if result.get('error'):
        return jsonify({'success': False, 'error': result['error']})
    
    # Load existing repos
    repos = load_repos_from_file()
    
    # Check if already exists
    for existing in repos:
        if existing['owner'] == owner and existing['repo'] == repo:
            return jsonify({'success': False, 'error': 'Repository already added'})
    
    # Add new repo
    repos.append({'token': token, 'owner': owner, 'repo': repo})
    
    # Save to file
    save_repos_to_file(repos)
    
    return jsonify({'success': True})

@app.route('/api/remove-github-repo', methods=['POST'])
def remove_github_repo():
    """Remove GitHub repository and update file"""
    data = request.json
    index = data.get('index', -1)
    
    repos = load_repos_from_file()
    if 0 <= index < len(repos):
        repos.pop(index)
        save_repos_to_file(repos)
        return jsonify({'success': True})
    
    return jsonify({'success': False})

@app.route('/api/list-all-files')
def list_all_files():
    """List files from local + all GitHub repos"""
    all_files = []
    
    # Get local files
    local_result = get_local_files()
    all_files.extend(local_result.get('files', []))
    
    # Get files from each GitHub repo
    repos = load_repos_from_file()
    for repo_config in repos:
        github_result = get_github_files(
            repo_config['token'],
            repo_config['owner'],
            repo_config['repo']
        )
        all_files.extend(github_result.get('files', []))
    
    return jsonify({'files': all_files})

@app.route('/api/load-file', methods=['POST'])
def load_file():
    """Load file from GitHub or local"""
    data = request.json
    filepath = data.get('filepath', '')
    source = data.get('source', 'local')
    repo = data.get('repo', '')
    
    if source == 'github':
        # Find the repo config
        repos = load_repos_from_file()
        for repo_config in repos:
            repo_name = f"{repo_config['owner']}/{repo_config['repo']}"
            if repo_name == repo:
                return jsonify(load_github_file(
                    repo_config['token'],
                    repo_config['owner'],
                    repo_config['repo'],
                    filepath
                ))
        
        return jsonify({'error': 'Repository not found'})
    else:
        if not filepath or not filepath.startswith(CODE_BASE_PATH):
            return jsonify({'error': 'Invalid file path'})
        
        try:
            with open(filepath, 'r') as f:
                content = f.read()
            return jsonify({'content': content, 'source': 'local'})
        except Exception as e:
            return jsonify({'error': str(e)})

@app.route('/api/save-file', methods=['POST'])
def save_file():
    """Save file to GitHub or local"""
    data = request.json
    filepath = data.get('filepath', '')
    content = data.get('content', '')
    source = data.get('source', 'local')
    repo = data.get('repo', '')
    sha = data.get('sha', '')
    
    if source == 'github':
        # Find the repo config
        repos = load_repos_from_file()
        for repo_config in repos:
            repo_name = f"{repo_config['owner']}/{repo_config['repo']}"
            if repo_name == repo:
                return jsonify(save_github_file(
                    repo_config['token'],
                    repo_config['owner'],
                    repo_config['repo'],
                    filepath,
                    content,
                    sha
                ))
        
        return jsonify({'success': False, 'error': 'Repository not found'})
    else:
        if not filepath or not filepath.startswith(CODE_BASE_PATH):
            return jsonify({'success': False, 'error': 'Invalid file path'})
        
        try:
            with open(filepath, 'w') as f:
                f.write(content)
            return jsonify({'success': True})
        except Exception as e:
            return jsonify({'success': False, 'error': str(e)})

if __name__ == '__main__':
    log = logging.getLogger('werkzeug')
    log.setLevel(logging.ERROR)
    
    print("="*60)
    print("SDOS Developer Workspace - Persistent GitHub Storage")
    print("="*60)
    print("Access: http://localhost:6001")
    print(f"Storage: {REPOS_FILE}")
    print("")
    print("Features:")
    print("  - GitHub repos saved to file")
    print("  - Persist across restarts")
    print("  - Multi-repository support")
    print("  - Edit and push to GitHub")
    print("")
    print("Press Ctrl+C to stop")
    print("="*60)
    
    # Load repos on startup
    repos = load_repos_from_file()
    if repos:
        print(f"Loaded {len(repos)} saved repositories")
    
    try:
        app.run(host='0.0.0.0', port=6001, debug=False, threaded=True, use_reloader=False)
    except KeyboardInterrupt:
        print("\n" + "="*60)
        print("Developer Workspace stopped")
        print("="*60)
        sys.exit(0)
