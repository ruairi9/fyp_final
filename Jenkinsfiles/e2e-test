pipeline {
    agent { label 'host-agent' }

    environment {
        KUBECONFIG    = '/home/ruairi/fyp-cluster/k3s.yaml'
        REGISTRY      = '192.168.121.50:30500'
        NAMESPACE     = 'integration'
        BACKEND_IMG   = 'sdos-backend'
        BACKEND_TAG   = 'latest'
        FRONTEND_PORT = '30091'
        REPORT_FILE   = 'e2e-test-report.txt'
    }

    stages {

        stage('Build') {
            steps {
                echo '============================================'
                echo ' STAGE 1 BUILD'
                echo ' Building Flask backend Docker image'
                echo '============================================'
                sh '''
                    echo "E2E Integration Test Report $(date)" > $REPORT_FILE
                    echo "============================================" >> $REPORT_FILE
                    mkdir -p /tmp/sdos-e2e/backend

                    cat > /tmp/sdos-e2e/backend/app.py <<EOF
from flask import Flask, jsonify
import os, datetime

app = Flask(__name__)

@app.route("/api/health")
def health():
    return jsonify({
        "status": "healthy",
        "service": "sdos-backend",
        "timestamp": datetime.datetime.utcnow().isoformat()
    })

@app.route("/api/message")
def message():
    return jsonify({
        "message": "Hello from the SDOS Flask backend!",
        "environment": os.environ.get("APP_ENV", "development"),
        "version": "1.0.0"
    })

@app.route("/api/status")
def status():
    return jsonify({
        "database": "connected",
        "cache": "connected",
        "uptime": "running",
        "pods": int(os.environ.get("REPLICA_COUNT", 1))
    })

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
EOF

                    cat > /tmp/sdos-e2e/backend/requirements.txt <<EOF
flask==3.0.0
gunicorn==21.2.0
EOF

                    cat > /tmp/sdos-e2e/backend/Dockerfile <<EOF
FROM python:3.11-alpine
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY app.py .
ENV APP_ENV=production
EXPOSE 5000
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "2", "app:app"]
EOF

                    docker login 192.168.121.50:30500 -u admin -p passadmin
                    docker build -t $REGISTRY/$BACKEND_IMG:$BACKEND_TAG /tmp/sdos-e2e/backend/
                    docker push $REGISTRY/$BACKEND_IMG:$BACKEND_TAG
                    echo "PASS: Backend image built and pushed to $REGISTRY"
                '''
            }
        }

        stage('Deploy') {
            steps {
                echo '============================================'
                echo ' STAGE 2 DEPLOY'
                echo ' Deploying Flask backend + nginx frontend'
                echo ' to the integration namespace'
                echo '============================================'
                sh '''
                    kubectl --kubeconfig=$KUBECONFIG create namespace $NAMESPACE --dry-run=client -o yaml | kubectl --kubeconfig=$KUBECONFIG apply -f -

                    kubectl --kubeconfig=$KUBECONFIG delete deployment sdos-backend  -n $NAMESPACE --ignore-not-found=true || true
                    kubectl --kubeconfig=$KUBECONFIG delete deployment sdos-frontend -n $NAMESPACE --ignore-not-found=true || true
                    kubectl --kubeconfig=$KUBECONFIG delete pod e2e-test-pod         -n $NAMESPACE --ignore-not-found=true || true
                    sleep 5

                    cat > /tmp/sdos-e2e/backend-deployment.yaml <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: sdos-backend
  namespace: $NAMESPACE
  labels:
    app: sdos-backend
    tier: backend
spec:
  replicas: 2
  selector:
    matchLabels:
      app: sdos-backend
  template:
    metadata:
      labels:
        app: sdos-backend
        tier: backend
    spec:
      imagePullSecrets:
      - name: registry-creds
      containers:
      - name: flask
        image: $REGISTRY/$BACKEND_IMG:$BACKEND_TAG
        imagePullPolicy: Always
        ports:
        - containerPort: 5000
        env:
        - name: APP_ENV
          value: "integration"
        - name: REPLICA_COUNT
          value: "2"
        resources:
          requests:
            memory: "64Mi"
            cpu: "50m"
          limits:
            memory: "128Mi"
            cpu: "200m"
        readinessProbe:
          httpGet:
            path: /api/health
            port: 5000
          initialDelaySeconds: 5
          periodSeconds: 5
---
apiVersion: v1
kind: Service
metadata:
  name: sdos-backend
  namespace: $NAMESPACE
spec:
  selector:
    app: sdos-backend
  ports:
  - port: 5000
    targetPort: 5000
EOF

                    cat > /tmp/sdos-e2e/frontend-deployment.yaml <<EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: sdos-frontend-config
  namespace: integration
data:
  default.conf: |
    server {
        listen 80;
        location / {
            add_header Content-Type text/html;
            return 200 "SDOS Frontend OK";
        }
        location /api/ {
            proxy_pass http://sdos-backend.integration.svc.cluster.local:5000;
            proxy_connect_timeout 5s;
            proxy_read_timeout 10s;
        }
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: sdos-frontend
  namespace: integration
  labels:
    app: sdos-frontend
    tier: frontend
spec:
  replicas: 1
  selector:
    matchLabels:
      app: sdos-frontend
  template:
    metadata:
      labels:
        app: sdos-frontend
        tier: frontend
    spec:
      containers:
      - name: nginx
        image: nginx:1.25.3
        ports:
        - containerPort: 80
        volumeMounts:
        - name: nginx-conf
          mountPath: /etc/nginx/conf.d/default.conf
          subPath: default.conf
        resources:
          requests:
            memory: "32Mi"
            cpu: "50m"
          limits:
            memory: "64Mi"
            cpu: "100m"
      volumes:
      - name: nginx-conf
        configMap:
          name: sdos-frontend-config
          items:
          - key: default.conf
            path: default.conf
---
apiVersion: v1
kind: Service
metadata:
  name: sdos-frontend
  namespace: integration
spec:
  type: NodePort
  selector:
    app: sdos-frontend
  ports:
  - port: 80
    targetPort: 80
    nodePort: 30091
EOF

                    kubectl --kubeconfig=$KUBECONFIG create secret docker-registry registry-creds \
                        --docker-server=$REGISTRY \
                        --docker-username=admin \
                        --docker-password=passadmin \
                        --namespace=$NAMESPACE \
                        --dry-run=client -o yaml | kubectl --kubeconfig=$KUBECONFIG apply -f -

                    kubectl --kubeconfig=$KUBECONFIG apply -f /tmp/sdos-e2e/backend-deployment.yaml
                    kubectl --kubeconfig=$KUBECONFIG apply -f /tmp/sdos-e2e/frontend-deployment.yaml

                    echo "Waiting for backend rollout..."
                    kubectl --kubeconfig=$KUBECONFIG rollout status deployment/sdos-backend -n $NAMESPACE --timeout=120s

                    echo "Waiting for frontend rollout..."
                    kubectl --kubeconfig=$KUBECONFIG rollout status deployment/sdos-frontend -n $NAMESPACE --timeout=300s

                    echo "All pods in integration namespace:"
                    kubectl --kubeconfig=$KUBECONFIG get pods -n $NAMESPACE
                    sleep 10
                '''
            }
        }

        stage('Integration Tests') {
            steps {
                echo '============================================'
                echo ' STAGE 3 INTEGRATION TESTS'
                echo ' Test pod runs inside the cluster'
                echo ' Tests the full frontend → backend chain'
                echo '============================================'
                sh '''
                    kubectl --kubeconfig=$KUBECONFIG run e2e-test-pod \
                        --image=curlimages/curl:latest \
                        --restart=Never \
                        --namespace=$NAMESPACE \
                        -- sh -c '
                            echo "=== E2E Integration Tests ==="
                            echo "Testing frontend -> backend communication"
                            echo "Waiting 15s for DNS and services to be ready..."
                            sleep 15
                            echo ""
                            PASS=0
                            FAIL=0

                            echo "Test 1: Backend /api/health via cluster DNS"
                            CODE=$(curl -s -o /dev/null -w "%{http_code}" \
                                http://sdos-backend.integration.svc.cluster.local:5000/api/health \
                                --connect-timeout 10)
                            if [ "$CODE" = "200" ]; then
                                echo "  PASS: Backend health check returned 200"
                                PASS=$((PASS+1))
                            else
                                echo "  FAIL: Backend returned $CODE"
                                FAIL=$((FAIL+1))
                            fi

                            echo "Test 2: Backend /api/health returns healthy status"
                            BODY=$(curl -s \
                                http://sdos-backend.integration.svc.cluster.local:5000/api/health \
                                --connect-timeout 10)
                            if echo "$BODY" | grep -q "healthy"; then
                                echo "  PASS: Backend returned healthy status"
                                PASS=$((PASS+1))
                            else
                                echo "  FAIL: Backend did not return healthy status"
                                FAIL=$((FAIL+1))
                            fi

                            echo "Test 3: Backend /api/message endpoint"
                            BODY=$(curl -s \
                                http://sdos-backend.integration.svc.cluster.local:5000/api/message \
                                --connect-timeout 10)
                            if echo "$BODY" | grep -q "Flask backend"; then
                                echo "  PASS: /api/message returned expected content"
                                PASS=$((PASS+1))
                            else
                                echo "  FAIL: /api/message unexpected response"
                                FAIL=$((FAIL+1))
                            fi

                            echo "Test 4: Backend /api/status endpoint"
                            BODY=$(curl -s \
                                http://sdos-backend.integration.svc.cluster.local:5000/api/status \
                                --connect-timeout 10)
                            if echo "$BODY" | grep -q "connected"; then
                                echo "  PASS: /api/status returned expected content"
                                PASS=$((PASS+1))
                            else
                                echo "  FAIL: /api/status unexpected response"
                                FAIL=$((FAIL+1))
                            fi

                            echo "Test 5: Frontend serves HTML page"
                            CODE=$(curl -s -o /dev/null -w "%{http_code}" \
                                http://sdos-frontend.integration.svc.cluster.local:80 \
                                --connect-timeout 10)
                            if [ "$CODE" = "200" ]; then
                                echo "  PASS: Frontend returned 200"
                                PASS=$((PASS+1))
                            else
                                echo "  FAIL: Frontend returned $CODE"
                                FAIL=$((FAIL+1))
                            fi

                            echo "Test 6: Frontend /api/health proxies to Flask backend"
                            BODY=$(curl -s \
                                http://sdos-frontend.integration.svc.cluster.local:80/api/health \
                                --connect-timeout 10)
                            if echo "$BODY" | grep -q "healthy"; then
                                echo "  PASS: Frontend correctly proxied to Flask backend"
                                PASS=$((PASS+1))
                            else
                                echo "  FAIL: Frontend did not proxy to backend"
                                FAIL=$((FAIL+1))
                            fi

                            echo "Test 7: End-to-end response time"
                            TIME=$(curl -s -o /dev/null -w "%{time_total}" \
                                http://sdos-frontend.integration.svc.cluster.local:80/api/message \
                                --connect-timeout 10)
                            if awk "BEGIN { exit !($TIME < 2.0) }"; then
                                echo "  PASS: E2E response time ${TIME}s (under 2s)"
                                PASS=$((PASS+1))
                            else
                                echo "  FAIL: E2E response time ${TIME}s (too slow)"
                                FAIL=$((FAIL+1))
                            fi

                            echo ""
                            echo "============================================"
                            echo "E2E Integration Tests: $PASS passed, $FAIL failed"
                            echo "============================================"

                            if [ "$FAIL" -gt "0" ]; then
                                exit 1
                            fi
                        '

                    kubectl --kubeconfig=$KUBECONFIG wait pod/e2e-test-pod                         -n $NAMESPACE --for=jsonpath="{.status.phase}"=Succeeded --timeout=120s 2>/dev/null ||                     kubectl --kubeconfig=$KUBECONFIG wait pod/e2e-test-pod                         -n $NAMESPACE --for=jsonpath="{.status.phase}"=Failed --timeout=120s 2>/dev/null || true
                    kubectl --kubeconfig=$KUBECONFIG logs e2e-test-pod -n $NAMESPACE 2>/dev/null || true

                    EXIT_CODE=$(kubectl --kubeconfig=$KUBECONFIG get pod e2e-test-pod \
                        -n $NAMESPACE \
                        -o jsonpath="{.status.containerStatuses[0].state.terminated.exitCode}" 2>/dev/null || echo "0")
                    kubectl --kubeconfig=$KUBECONFIG delete pod e2e-test-pod -n $NAMESPACE --ignore-not-found=true

                    if [ "$EXIT_CODE" != "0" ] && [ "$EXIT_CODE" != "" ]; then
                        echo "FAIL: Integration test pod failed"
                        exit 1
                    fi

                    echo ""
                    echo "============================================"
                    echo "  Frontend: http://192.168.121.20:$FRONTEND_PORT"
                    echo "  Backend:  internal only (cluster DNS)"
                    echo "============================================"
                    kubectl --kubeconfig=$KUBECONFIG logs e2e-test-pod -n $NAMESPACE 2>/dev/null >> $REPORT_FILE || true
                    echo "" >> $REPORT_FILE
                    echo "=== TEST COMPLETE: $(date) ===" >> $REPORT_FILE
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'e2e-test-report.txt', fingerprint: true, allowEmptyArchive: true
        }
        success {
            echo 'E2E integration tests passed - frontend talks to backend correctly!'
        }
        failure {
            sh '''
                echo "Pipeline failed - cleaning up..."
                kubectl --kubeconfig=$KUBECONFIG delete deployment sdos-backend         -n $NAMESPACE --ignore-not-found=true || true
                kubectl --kubeconfig=$KUBECONFIG delete deployment sdos-frontend         -n $NAMESPACE --ignore-not-found=true || true
                kubectl --kubeconfig=$KUBECONFIG delete service    sdos-backend         -n $NAMESPACE --ignore-not-found=true || true
                kubectl --kubeconfig=$KUBECONFIG delete service    sdos-frontend         -n $NAMESPACE --ignore-not-found=true || true
                kubectl --kubeconfig=$KUBECONFIG delete configmap  sdos-frontend-config -n $NAMESPACE --ignore-not-found=true || true
                kubectl --kubeconfig=$KUBECONFIG delete pod        e2e-test-pod         -n $NAMESPACE --ignore-not-found=true || true
            '''
        }
        always {
            sh 'rm -rf /tmp/sdos-e2e || true'
        }
    }
}
