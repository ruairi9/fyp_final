pipeline {
    agent { label 'host-agent' }

    environment {
        KUBECONFIG      = '/home/ruairi/fyp-cluster/k3s.yaml'
        APP_NAME        = 'sdos-nginx'
        DEV_NAMESPACE   = 'development'
        STG_NAMESPACE   = 'staging'
        PRD_NAMESPACE   = 'production'
        DEV_PORT        = '30081'
        STG_PORT        = '30083'
        PRD_PORT        = '30082'
    }

    stages {

        stage('Build') {
            steps {
                echo '============================================'
                echo ' STAGE 1 — BUILD'
                echo ' Creating nginx Kubernetes manifests'
                echo '============================================'
                sh '''
                    mkdir -p /tmp/sdos-nginx

                    # Dev deployment manifest
                    cat > /tmp/sdos-nginx/dev-deployment.yaml <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: sdos-nginx-dev
  namespace: development
  labels:
    app: sdos-nginx
    env: development
spec:
  replicas: 2
  selector:
    matchLabels:
      app: sdos-nginx
      env: development
  template:
    metadata:
      labels:
        app: sdos-nginx
        env: development
    spec:
      nodeSelector:
        node-role: integration
      containers:
      - name: nginx
        image: nginx:alpine
        ports:
        - containerPort: 80
        resources:
          requests:
            memory: "32Mi"
            cpu: "50m"
          limits:
            memory: "64Mi"
            cpu: "100m"
---
apiVersion: v1
kind: Service
metadata:
  name: sdos-nginx-dev
  namespace: development
spec:
  type: NodePort
  selector:
    app: sdos-nginx
    env: development
  ports:
  - port: 80
    targetPort: 80
    nodePort: 30081
EOF

                    # Staging deployment manifest (separate namespace, separate workload)
                    cat > /tmp/sdos-nginx/stg-deployment.yaml <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: sdos-nginx-stg
  namespace: staging
  labels:
    app: sdos-nginx
    env: staging
spec:
  replicas: 2
  selector:
    matchLabels:
      app: sdos-nginx
      env: staging
  template:
    metadata:
      labels:
        app: sdos-nginx
        env: staging
    spec:
      nodeSelector:
        node-role: integration
      containers:
      - name: nginx
        image: nginx:alpine
        ports:
        - containerPort: 80
        resources:
          requests:
            memory: "32Mi"
            cpu: "50m"
          limits:
            memory: "64Mi"
            cpu: "100m"
---
apiVersion: v1
kind: Service
metadata:
  name: sdos-nginx-stg
  namespace: staging
spec:
  type: NodePort
  selector:
    app: sdos-nginx
    env: staging
  ports:
  - port: 80
    targetPort: 80
    nodePort: 30083
EOF

                    # Production deployment manifest
                    cat > /tmp/sdos-nginx/prod-deployment.yaml <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: sdos-nginx-prod
  namespace: production
  labels:
    app: sdos-nginx
    env: production
spec:
  replicas: 3
  selector:
    matchLabels:
      app: sdos-nginx
      env: production
  template:
    metadata:
      labels:
        app: sdos-nginx
        env: production
    spec:
      nodeSelector:
        node-role: security-testing
      containers:
      - name: nginx
        image: nginx:alpine
        ports:
        - containerPort: 80
        resources:
          requests:
            memory: "32Mi"
            cpu: "50m"
          limits:
            memory: "64Mi"
            cpu: "100m"
---
apiVersion: v1
kind: Service
metadata:
  name: sdos-nginx-prod
  namespace: production
spec:
  type: NodePort
  selector:
    app: sdos-nginx
    env: production
  ports:
  - port: 80
    targetPort: 80
    nodePort: 30082
EOF

                    echo "All manifests created successfully"
                '''
            }
        }

        stage('Test') {
            steps {
                echo '============================================'
                echo ' STAGE 2 — TEST'
                echo ' Deploying nginx to worker-dev'
                echo '============================================'
                sh '''
                    kubectl --kubeconfig=$KUBECONFIG create namespace development --dry-run=client -o yaml | kubectl --kubeconfig=$KUBECONFIG apply -f -
                    kubectl --kubeconfig=$KUBECONFIG apply -f /tmp/sdos-nginx/dev-deployment.yaml

                    echo "Waiting for dev deployment to be ready..."
                    kubectl --kubeconfig=$KUBECONFIG rollout status deployment/sdos-nginx-dev -n development --timeout=120s

                    echo "Dev pods:"
                    kubectl --kubeconfig=$KUBECONFIG get pods -n development -l app=sdos-nginx

                    sleep 5
                    HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" http://192.168.121.20:30081 --connect-timeout 10 || echo "000")
                    echo "HTTP response code: $HTTP_CODE"
                    if [ "$HTTP_CODE" = "200" ]; then
                        echo "SUCCESS: nginx is responding on worker-dev!"
                    else
                        echo "WARNING: Got HTTP $HTTP_CODE - nginx may still be starting"
                    fi
                '''
            }
        }

        stage('Staging') {
            steps {
                echo '============================================'
                echo ' STAGE 3 — STAGING'
                echo ' Deploying to dedicated staging namespace'
                echo ' Running test pod inside Kubernetes cluster'
                echo '============================================'
                sh '''
                    kubectl --kubeconfig=$KUBECONFIG create namespace staging --dry-run=client -o yaml | kubectl --kubeconfig=$KUBECONFIG apply -f -
                    kubectl --kubeconfig=$KUBECONFIG apply -f /tmp/sdos-nginx/stg-deployment.yaml

                    echo "Waiting for staging deployment to be ready..."
                    kubectl --kubeconfig=$KUBECONFIG rollout status deployment/sdos-nginx-stg -n staging --timeout=120s

                    echo "Staging pods:"
                    kubectl --kubeconfig=$KUBECONFIG get pods -n staging -l app=sdos-nginx

                    sleep 5

                    echo "============================================"
                    echo " Launching test pod inside Kubernetes..."
                    echo " Tests run from inside the cluster via DNS"
                    echo "============================================"

                    kubectl --kubeconfig=$KUBECONFIG run stg-test-pod \
                        --image=curlimages/curl:latest \
                        --restart=Never \
                        --namespace=staging \
                        --rm \
                        --attach \
                        --timeout=60s \
                        -- sh -c '
                            echo "=== Test Pod Running Inside Kubernetes ==="
                            PASS=0
                            FAIL=0

                            CODE=$(curl -s -o /dev/null -w "%{http_code}" http://sdos-nginx-stg.staging.svc.cluster.local:80 --connect-timeout 10 || echo "000")
                            if [ "$CODE" = "200" ]; then
                                echo "PASS: HTTP 200 response"
                                PASS=$((PASS+1))
                            else
                                echo "FAIL: HTTP $CODE response"
                                FAIL=$((FAIL+1))
                            fi

                            BODY=$(curl -s http://sdos-nginx-stg.staging.svc.cluster.local:80 --connect-timeout 10 || echo "")
                            if echo "$BODY" | grep -qiE "nginx|html|welcome"; then
                                echo "PASS: Response contains expected content"
                                PASS=$((PASS+1))
                            else
                                echo "FAIL: Unexpected response body"
                                FAIL=$((FAIL+1))
                            fi

                            TIME=$(curl -s -o /dev/null -w "%{time_total}" http://sdos-nginx-stg.staging.svc.cluster.local:80 --connect-timeout 10 || echo "999")
                            echo "Response time: ${TIME}s"
                            if awk "BEGIN { exit !($TIME < 2.0) }"; then
                                echo "PASS: Response time under 2s (${TIME}s)"
                                PASS=$((PASS+1))
                            else
                                echo "FAIL: Response time too slow (${TIME}s)"
                                FAIL=$((FAIL+1))
                            fi

                            echo "============================================"
                            echo "Staging Tests (from test pod): $PASS passed, $FAIL failed"
                            echo "============================================"

                            if [ "$FAIL" -gt "0" ]; then
                                exit 1
                            fi
                        ' || true

                    PODS=$(kubectl --kubeconfig=$KUBECONFIG get pods -n staging -l app=sdos-nginx --field-selector=status.phase=Running --no-headers 2>/dev/null | wc -l)
                    echo "Running staging pods: $PODS"
                    if [ "$PODS" -ge "1" ]; then
                        echo "PASS: Staging pods running"
                    else
                        echo "FAIL: No staging pods running"
                        exit 1
                    fi
                '''
            }
        }

        stage('Load') {
            steps {
                echo '============================================'
                echo ' STAGE 4 — LOAD TEST'
                echo ' Running load test with response time metrics'
                echo ' Gates production if avg response time > 3s'
                echo '============================================'
                sh '''
                    echo "Running load test against http://192.168.121.20:30081"
                    echo "Sending 50 requests..."

                    SUCCESS=0
                    FAIL=0
                    TOTAL_TIME="0"

                    for i in $(seq 1 50); do
                        CODE=$(curl -s -o /dev/null -w "%{http_code}" http://192.168.121.20:30081 --connect-timeout 5 || echo "000")
                        TIME=$(curl -s -o /dev/null -w "%{time_total}" http://192.168.121.20:30081 --connect-timeout 5 || echo "0")
                        if [ "$CODE" = "200" ]; then
                            SUCCESS=$((SUCCESS+1))
                        else
                            FAIL=$((FAIL+1))
                        fi
                        TOTAL_TIME=$(echo "$TOTAL_TIME + $TIME" | bc)
                    done

                    TOTAL=$((SUCCESS+FAIL))
                    RATE=$(echo "scale=1; $SUCCESS * 100 / $TOTAL" | bc)
                    AVG_TIME=$(echo "scale=3; $TOTAL_TIME / $TOTAL" | bc)

                    echo "============================================"
                    echo "Load Test Results:"
                    echo "  Total requests:    $TOTAL"
                    echo "  Successful:        $SUCCESS"
                    echo "  Failed:            $FAIL"
                    echo "  Success rate:      $RATE%"
                    echo "  Avg response time: ${AVG_TIME}s"
                    echo "============================================"

                    if [ "$SUCCESS" -lt "40" ]; then
                        echo "FAIL: Success rate too low — blocking production deploy"
                        exit 1
                    fi

                    if awk "BEGIN { exit !($AVG_TIME > 3.0) }"; then
                        echo "FAIL: Avg response time too high (${AVG_TIME}s) — blocking production deploy"
                        exit 1
                    fi

                    echo "PASS: Load test passed — avg response time ${AVG_TIME}s"
                '''
            }
        }

        stage('Production') {
            steps {
                echo '============================================'
                echo ' STAGE 5 — PRODUCTION'
                echo ' Deploying nginx to worker-production'
                echo ' Running test pod inside Kubernetes cluster'
                echo '============================================'
                sh '''
                    kubectl --kubeconfig=$KUBECONFIG create namespace production --dry-run=client -o yaml | kubectl --kubeconfig=$KUBECONFIG apply -f -
                    kubectl --kubeconfig=$KUBECONFIG apply -f /tmp/sdos-nginx/prod-deployment.yaml

                    echo "Waiting for production deployment to be ready..."
                    kubectl --kubeconfig=$KUBECONFIG rollout status deployment/sdos-nginx-prod -n production --timeout=120s

                    echo "Production pods:"
                    kubectl --kubeconfig=$KUBECONFIG get pods -n production -l app=sdos-nginx

                    sleep 5

                    echo "============================================"
                    echo " Launching test pod inside Kubernetes..."
                    echo " Tests run from inside the cluster via DNS"
                    echo "============================================"

                    kubectl --kubeconfig=$KUBECONFIG run prod-test-pod \
                        --image=curlimages/curl:latest \
                        --restart=Never \
                        --namespace=production \
                        --rm \
                        --attach \
                        --timeout=60s \
                        -- sh -c '
                            echo "=== Test Pod Running Inside Kubernetes ==="
                            PASS=0
                            FAIL=0

                            CODE=$(curl -s -o /dev/null -w "%{http_code}" http://sdos-nginx-prod.production.svc.cluster.local:80 --connect-timeout 10 || echo "000")
                            if [ "$CODE" = "200" ]; then
                                echo "PASS: HTTP 200 response"
                                PASS=$((PASS+1))
                            else
                                echo "FAIL: HTTP $CODE response"
                                FAIL=$((FAIL+1))
                            fi

                            BODY=$(curl -s http://sdos-nginx-prod.production.svc.cluster.local:80 --connect-timeout 10 || echo "")
                            if echo "$BODY" | grep -qiE "nginx|html|welcome"; then
                                echo "PASS: Response contains expected content"
                                PASS=$((PASS+1))
                            else
                                echo "FAIL: Unexpected response body"
                                FAIL=$((FAIL+1))
                            fi

                            TIME=$(curl -s -o /dev/null -w "%{time_total}" http://sdos-nginx-prod.production.svc.cluster.local:80 --connect-timeout 10 || echo "999")
                            echo "Response time: ${TIME}s"
                            if awk "BEGIN { exit !($TIME < 2.0) }"; then
                                echo "PASS: Response time under 2s (${TIME}s)"
                                PASS=$((PASS+1))
                            else
                                echo "FAIL: Response time too slow (${TIME}s)"
                                FAIL=$((FAIL+1))
                            fi

                            echo "============================================"
                            echo "Production Tests (from test pod): $PASS passed, $FAIL failed"
                            echo "============================================"

                            if [ "$FAIL" -gt "0" ]; then
                                echo "WARNING: $FAIL production test(s) failed"
                            else
                                echo "DEPLOYMENT COMPLETE — all production tests passed!"
                            fi
                        ' || true

                    echo ""
                    echo "============================================"
                    echo "  Dev:        http://192.168.121.20:30081"
                    echo "  Staging:    http://192.168.121.20:30083"
                    echo "  Production: http://192.168.121.30:30082"
                    echo "============================================"
                '''
            }
        }
    }

    post {
        success {
            echo 'nginx deployed successfully to staging and production!'
        }
        failure {
            sh '''
                echo "Pipeline failed - cleaning up..."
                kubectl --kubeconfig=$KUBECONFIG delete deployment sdos-nginx-dev -n development --ignore-not-found=true || true
                kubectl --kubeconfig=$KUBECONFIG delete deployment sdos-nginx-stg -n staging     --ignore-not-found=true || true
                kubectl --kubeconfig=$KUBECONFIG delete deployment sdos-nginx-prod -n production --ignore-not-found=true || true
                kubectl --kubeconfig=$KUBECONFIG delete pod stg-test-pod  -n staging     --ignore-not-found=true || true
                kubectl --kubeconfig=$KUBECONFIG delete pod prod-test-pod -n production  --ignore-not-found=true || true
            '''
        }
        always {
            sh 'rm -rf /tmp/sdos-nginx || true'
        }
    }
}
