pipeline {
    agent { label 'host-agent' }

    environment {
        KUBECONFIG   = '/home/ruairi/fyp-cluster/k3s.yaml'
        PROMETHEUS   = 'http://192.168.121.50:32090'
        GRAFANA      = 'http://192.168.121.50:32030'
        REPORT_FILE  = 'monitoring-test-report.txt'
    }

    stages {

        stage('Build') {
            steps {
                sh '''
                    echo "Monitoring Test $(date)" > $REPORT_FILE
                    PASS=0; FAIL=0

                    for POD in prometheus grafana loki promtail docker-registry; do
                        COUNT=$(kubectl --kubeconfig=$KUBECONFIG get pods -n monitoring --no-headers 2>/dev/null | grep "$POD" | grep -c "Running" || true)
                        [ -z "$COUNT" ] && COUNT=0
                        if [ "$COUNT" -gt "0" ] 2>/dev/null; then
                            echo "  OK: $POD running ($COUNT)"; PASS=$((PASS+1))
                        else
                            echo "  FAIL: $POD not running"; FAIL=$((FAIL+1))
                        fi
                    done

                    echo "Pods: $PASS up, $FAIL down" | tee -a $REPORT_FILE
                    [ "$FAIL" -gt "0" ] && exit 1 || true
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    PASS=0

                    CODE=$(curl -s -o /dev/null -w "%{http_code}" $PROMETHEUS/-/healthy --connect-timeout 10 || echo "000")
                    if [ "$CODE" = "200" ]; then
                        echo "  OK: Prometheus healthy"; PASS=$((PASS+1))
                    else
                        echo "  FAIL: Prometheus returned $CODE"; exit 1
                    fi

                    TARGETS=$(curl -s "$PROMETHEUS/api/v1/targets" --connect-timeout 10 \
                        | python3 -c "import sys,json; d=json.load(sys.stdin); \
                        active=[t for t in d.get('data',{}).get('activeTargets',[]) if t.get('health')=='up']; \
                        print(len(active))" 2>/dev/null || echo "0")
                    echo "  Targets scraping: $TARGETS"

                    RESULT=$(curl -s "$PROMETHEUS/api/v1/query?query=up" --connect-timeout 10 \
                        | python3 -c "import sys,json; d=json.load(sys.stdin); \
                        print(len(d.get('data',{}).get('result',[])))" 2>/dev/null || echo "0")
                    echo "  Metric results: $RESULT"

                    echo "Prometheus: healthy, $TARGETS targets, $RESULT metrics" >> $REPORT_FILE
                '''
            }
        }

        stage('Staging') {
            steps {
                sh '''
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" $GRAFANA --connect-timeout 10 || echo "000")
                    if [ "$CODE" = "200" ] || [ "$CODE" = "302" ]; then
                        echo "  OK: Grafana reachable (HTTP $CODE)"
                    else
                        echo "  FAIL: Grafana HTTP $CODE"; exit 1
                    fi

                    curl -s -o /dev/null -w "%{http_code}" $GRAFANA/api/health --connect-timeout 10 | grep -q 200 && echo "  OK: API healthy"

                    DASHBOARDS=$(curl -s -u admin:admin $GRAFANA/api/search --connect-timeout 10 \
                        | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")
                    echo "  Dashboards: $DASHBOARDS"
                    echo "Grafana: up, $DASHBOARDS dashboards" >> $REPORT_FILE
                '''
            }
        }

        stage('Load') {
            steps {
                sh '''
                    RUNNING=$(kubectl --kubeconfig=$KUBECONFIG get pods -n monitoring --no-headers 2>/dev/null | grep loki | grep -c Running || true)
                    PROMTAIL=$(kubectl --kubeconfig=$KUBECONFIG get pods -n monitoring --no-headers 2>/dev/null | grep promtail | grep -c Running || true)
                    echo "  Loki pods: ${RUNNING:-0}, Promtail pods: ${PROMTAIL:-0}"

                    LOKI_PORT=$(kubectl --kubeconfig=$KUBECONFIG get svc loki -n monitoring \
                        -o jsonpath='{.spec.ports[0].nodePort}' 2>/dev/null || echo "")
                    if [ -z "$LOKI_PORT" ]; then
                        echo "  WARN: Loki not exposed via NodePort, skipping API check"
                    else
                        LOKI_API="http://192.168.121.50:$LOKI_PORT"
                        for i in 1 2 3; do
                            CODE=$(curl -s -o /dev/null -w "%{http_code}" $LOKI_API/ready --connect-timeout 5 || echo "000")
                            [ "$CODE" = "200" ] && break
                            sleep 5
                        done
                        if [ "$CODE" = "200" ]; then
                            echo "  OK: Loki API ready"
                        else
                            echo "  WARN: Loki API returned $CODE"
                        fi
                    fi
                    echo "Loki: ${RUNNING:-0} pods, ${PROMTAIL:-0} promtail" >> $REPORT_FILE
                '''
            }
        }

        stage('Production') {
            // monitoring node fills up fast with prometheus data
            steps {
                sh '''
                    cd /home/ruairi/fyp-cluster
                    DISK=$(vagrant ssh worker-monitoring -c "df -P / | awk 'NR==2{print \$5}'" 2>/dev/null | tr -d '%\r\n ' | grep -Eo '[0-9]+')
                    [ -z "$DISK" ] && DISK=0
                    echo "  worker-monitoring disk: ${DISK}%"
                    if [ "$DISK" -gt "90" ] 2>/dev/null; then
                        echo "  WARN: monitoring disk high - prometheus data may need pruning"
                    fi
                    echo "Disk: ${DISK}%" >> $REPORT_FILE
                    echo "---" >> $REPORT_FILE
                    cat $REPORT_FILE
                '''
                archiveArtifacts artifacts: 'monitoring-test-report.txt', fingerprint: true
            }
        }
    }

    post {
        success { echo 'Monitoring stack healthy' }
        failure { echo 'Monitoring check failed' }
    }
}
