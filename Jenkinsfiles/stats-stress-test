pipeline {
    agent { label 'host-agent' }

    environment {
        KUBECONFIG    = '/home/ruairi/fyp-cluster/k3s.yaml'
        VAGRANT_DIR   = '/home/ruairi/fyp-cluster'
        REPORT_FILE   = 'stats-stress-report.txt'
        MAX_CPU_PCT   = '85'
        MAX_RAM_PCT   = '85'
        TEST_DURATION = '30'
    }

    stages {

        stage('Before') {
            steps {
                echo '============================================'
                echo ' STAGE 1 — BEFORE SNAPSHOT'
                echo ' Recording all stats before stress'
                echo '============================================'
                sh '''
                    echo "SDOS Stats Stress Test — $(date)" > $REPORT_FILE
                    echo "============================================" >> $REPORT_FILE

                    echo "" >> $REPORT_FILE
                    echo "=== BEFORE STRESS — HOST RAM ===" >> $REPORT_FILE
                    free -m | awk 'NR==2{
                        printf "Total RAM Usage:   %.1f%%\n", ($3/$2)*100
                        printf "Available Memory:  %.1f%%\n", ($7/$2)*100
                    }' >> $REPORT_FILE
                    free -m | awk 'NR==3{
                        if ($2>0) printf "Swap Usage:        %.1f%%\n", ($3/$2)*100
                        else print "Swap Usage:        0%"
                    }' >> $REPORT_FILE
                    awk '/^pgfault /{pf=$2} /^pgmajfault /{pmf=$2} END{
                        printf "Page Faults Total: %d\n", (pf+pmf)/1000
                    }' /proc/vmstat >> $REPORT_FILE
                    awk '/oom_kill/{print "OOM Events:        "$2}' /proc/vmstat >> $REPORT_FILE
                    perf stat -e cache-misses -a sleep 0.1 2>&1 | awk '/cache-misses/{
                        gsub(",","",$1); printf "Cache Faults:      %d\n", $1/1000
                    }' >> $REPORT_FILE

                    echo "" >> $REPORT_FILE
                    echo "=== BEFORE STRESS — HOST CPU ===" >> $REPORT_FILE
                    mpstat 1 1 | awk '/Average/{
                        printf "CPU Utilisation:   %.1f%%\n", 100-$NF
                        printf "CPU Steal Time:    %.1f%%\n", $9
                        printf "I/O Waits:         %.1f%%\n", $6
                    }' >> $REPORT_FILE

                    echo "" >> $REPORT_FILE
                    echo "=== BEFORE STRESS — HOST DISK ===" >> $REPORT_FILE
                    iostat -x 1 1 | awk '/^nvme/{
                        printf "I/O Throughput:    %.2f MB/s\n", ($3+$9)/1024
                        printf "Disk IOPS:         %.1f/sec\n", $2+$8
                        printf "Disk Latency:      %.2f ms\n", $6
                    }' >> $REPORT_FILE

                    echo "" >> $REPORT_FILE
                    echo "=== BEFORE STRESS — VMs ===" >> $REPORT_FILE
                    cd $VAGRANT_DIR
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- $VM ---" >> $WORKSPACE/$REPORT_FILE
                        vagrant ssh $VM -c "
                            echo -n 'vCPU %:     '
                            top -bn2 | grep 'Cpu' | tail -1 | awk '{printf \"%.1f%%\n\", 100-\$8}'
                            echo -n 'RAM %:      '
                            free -m | awk 'NR==2{printf \"%.1f%%\n\", (\$3/\$2)*100}'
                            echo -n 'Steal Time: '
                            top -bn1 | grep 'Cpu' | awk '{printf \"%.1f%%\n\", \$9}'
                            echo -n 'Disk I/O:   '
                            iostat -d -m 1 2 | grep vda | head -1 | awk '{printf \"%.2f MB/s\n\", \$3+\$4}'
                        " 2>/dev/null | grep -v fog | grep -v WARNING >> $WORKSPACE/$REPORT_FILE
                        echo "" >> $WORKSPACE/$REPORT_FILE
                    done

                    cat $REPORT_FILE
                '''
            }
        }

        stage('Stress') {
            steps {
                echo '============================================'
                echo ' STAGE 2 — CPU + RAM STRESS'
                echo ' 50% CPU and 50% RAM — NO disk stress'
                echo ' Safety cutoff at 85% on any VM'
                echo '============================================'
                sh '''
                    cd $VAGRANT_DIR

                    # Install stress-ng on all VMs
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh $VM -c "which stress-ng > /dev/null 2>&1 || sudo apt-get install -y stress-ng -qq > /dev/null 2>&1" 2>/dev/null &
                    done
                    wait

                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "=== STRESS STARTED: $(date) ===" >> $WORKSPACE/$REPORT_FILE

                    # Start CPU + RAM stress on all VMs (NO disk stress)
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh $VM -c "
                            CPUS=\$(nproc)
                            HALF=\$(( CPUS / 2 ))
                            [ \$HALF -lt 1 ] && HALF=1
                            nohup stress-ng \
                                --cpu \$HALF --cpu-load 50 \
                                --vm 1 --vm-bytes 50% \
                                --timeout ${TEST_DURATION}s \
                                > /tmp/stress.log 2>&1 &
                        " 2>/dev/null &
                    done
                    wait

                    sleep 15

                    # Safety check — kill stress if any VM goes over 85%
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        CPU=$(vagrant ssh $VM -c "top -bn2 | grep Cpu | tail -1 | awk '{printf \"%.0f\", 100-\$8}'" 2>/dev/null | tail -1 || echo "0")
                        RAM=$(vagrant ssh $VM -c "free | grep Mem | awk '{printf \"%.0f\", \$3/\$2*100}'" 2>/dev/null | tail -1 || echo "0")
                        echo "$VM — CPU:${CPU}% RAM:${RAM}%"
                        if [ "$CPU" -gt "$MAX_CPU_PCT" ] || [ "$RAM" -gt "$MAX_RAM_PCT" ] 2>/dev/null; then
                            echo "WARNING: $VM over safety limit — killing stress"
                            vagrant ssh $VM -c "sudo pkill -f stress-ng 2>/dev/null; true" 2>/dev/null || true
                        fi
                    done

                    echo "Stress running — waiting for completion..."
                    sleep 20
                '''
            }
        }

        stage('After') {
            steps {
                echo '============================================'
                echo ' STAGE 3 — AFTER SNAPSHOT'
                echo ' Recording all stats during/after stress'
                echo '============================================'
                sh '''
                    echo "" >> $REPORT_FILE
                    echo "=== AFTER STRESS — HOST RAM ===" >> $REPORT_FILE
                    free -m | awk 'NR==2{
                        printf "Total RAM Usage:   %.1f%%\n", ($3/$2)*100
                        printf "Available Memory:  %.1f%%\n", ($7/$2)*100
                    }' >> $REPORT_FILE
                    free -m | awk 'NR==3{
                        if ($2>0) printf "Swap Usage:        %.1f%%\n", ($3/$2)*100
                        else print "Swap Usage:        0%"
                    }' >> $REPORT_FILE
                    awk '/^pgfault /{pf=$2} /^pgmajfault /{pmf=$2} END{
                        printf "Page Faults Total: %d\n", (pf+pmf)/1000
                    }' /proc/vmstat >> $REPORT_FILE
                    awk '/oom_kill/{print "OOM Events:        "$2}' /proc/vmstat >> $REPORT_FILE
                    perf stat -e cache-misses -a sleep 0.1 2>&1 | awk '/cache-misses/{
                        gsub(",","",$1); printf "Cache Faults:      %d\n", $1/1000
                    }' >> $REPORT_FILE

                    echo "" >> $REPORT_FILE
                    echo "=== AFTER STRESS — HOST CPU ===" >> $REPORT_FILE
                    mpstat 1 1 | awk '/Average/{
                        printf "CPU Utilisation:   %.1f%%\n", 100-$NF
                        printf "CPU Steal Time:    %.1f%%\n", $9
                        printf "I/O Waits:         %.1f%%\n", $6
                    }' >> $REPORT_FILE

                    echo "" >> $REPORT_FILE
                    echo "=== AFTER STRESS — HOST DISK ===" >> $REPORT_FILE
                    iostat -x 1 1 | awk '/^nvme/{
                        printf "I/O Throughput:    %.2f MB/s\n", ($3+$9)/1024
                        printf "Disk IOPS:         %.1f/sec\n", $2+$8
                        printf "Disk Latency:      %.2f ms\n", $6
                    }' >> $REPORT_FILE

                    echo "" >> $REPORT_FILE
                    echo "=== AFTER STRESS — VMs ===" >> $REPORT_FILE
                    cd $VAGRANT_DIR
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- $VM ---" >> $WORKSPACE/$REPORT_FILE
                        vagrant ssh $VM -c "
                            echo -n 'vCPU %:     '
                            top -bn2 | grep 'Cpu' | tail -1 | awk '{printf \"%.1f%%\n\", 100-\$8}'
                            echo -n 'RAM %:      '
                            free -m | awk 'NR==2{printf \"%.1f%%\n\", (\$3/\$2)*100}'
                            echo -n 'Steal Time: '
                            top -bn1 | grep 'Cpu' | awk '{printf \"%.1f%%\n\", \$9}'
                            echo -n 'Disk I/O:   '
                            iostat -d -m 1 2 | grep vda | head -1 | awk '{printf \"%.2f MB/s\n\", \$3+\$4}'
                        " 2>/dev/null | grep -v fog | grep -v WARNING >> $WORKSPACE/$REPORT_FILE
                        echo "" >> $WORKSPACE/$REPORT_FILE
                    done
                '''
            }
        }

        stage('Recovery') {
            steps {
                echo '============================================'
                echo ' STAGE 4 — CLEANUP + RECOVERY'
                echo ' Kill all stress, wait, record recovery'
                echo '============================================'
                sh '''
                    cd $VAGRANT_DIR

                    # Kill all stress processes
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh $VM -c "sudo pkill -f stress-ng 2>/dev/null; sudo pkill -f stress 2>/dev/null; true" 2>/dev/null &
                    done
                    wait

                    sleep 15

                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "=== RECOVERY — VMs (15s after stress) ===" >> $WORKSPACE/$REPORT_FILE
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- $VM ---" >> $WORKSPACE/$REPORT_FILE
                        vagrant ssh $VM -c "
                            echo -n 'vCPU %:     '
                            top -bn2 | grep 'Cpu' | tail -1 | awk '{printf \"%.1f%%\n\", 100-\$8}'
                            echo -n 'RAM %:      '
                            free -m | awk 'NR==2{printf \"%.1f%%\n\", (\$3/\$2)*100}'
                        " 2>/dev/null | grep -v fog | grep -v WARNING >> $WORKSPACE/$REPORT_FILE
                        echo "" >> $WORKSPACE/$REPORT_FILE
                    done

                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "=== TEST COMPLETE: $(date) ===" >> $WORKSPACE/$REPORT_FILE

                    echo ""
                    echo "╔════════════════════════════════════════╗"
                    echo "║      STATS STRESS TEST REPORT          ║"
                    echo "╚════════════════════════════════════════╝"
                    cat $WORKSPACE/$REPORT_FILE
                '''
                archiveArtifacts artifacts: 'stats-stress-report.txt', fingerprint: true
            }
        }
    }

    post {
        always {
            sh '''
                cd /home/ruairi/fyp-cluster 2>/dev/null || true
                for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                    vagrant ssh $VM -c "
                        sudo pkill -f stress-ng 2>/dev/null || true
                        sudo pkill -f stress 2>/dev/null || true
                        rm -f /tmp/stress.log
                    " 2>/dev/null &
                done
                wait
                echo "All VMs cleaned up"
            '''
        }
        success { echo 'Stress test complete — check stats-stress-report.txt in artifacts' }
        failure { echo 'Stress test failed — all stress processes cleaned up' }
    }
}
