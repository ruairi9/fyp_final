pipeline {
    agent { label 'host-agent' }

    environment {
        KUBECONFIG    = '/home/ruairi/fyp-cluster/k3s.yaml'
        VAGRANT_DIR   = '/home/ruairi/fyp-cluster'
        REPORT_FILE   = 'stats-stress-report.txt'
        MAX_CPU_PCT   = '85'
        MAX_RAM_PCT   = '85'
        TEST_DURATION = '30'
    }

    stages {

        stage('Before') {
            steps {
                echo ' Recording all stats before stress'
                sh '''
                    echo "SDOS Stats Stress Test $(date)" > $WORKSPACE/$REPORT_FILE
                    echo "============================================" >> $WORKSPACE/$REPORT_FILE

                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "=== BEFORE STRESS HOST RAM ===" >> $WORKSPACE/$REPORT_FILE
                    free -m | awk 'NR==2{print "Total RAM Usage:   " sprintf("%.1f", ($3/$2)*100) "%"; print "Available Memory:  " sprintf("%.1f", ($7/$2)*100) "%"}' >> $WORKSPACE/$REPORT_FILE
                    free -m | awk 'NR==3{if ($2>0) print "Swap Usage:        " sprintf("%.1f", ($3/$2)*100) "%"; else print "Swap Usage:        0%"}' >> $WORKSPACE/$REPORT_FILE
                    awk '/^pgfault /{pf=$2} /^pgmajfault /{pmf=$2} END{print "Page Faults Total: " int((pf+pmf)/1000)}' /proc/vmstat >> $WORKSPACE/$REPORT_FILE
                    awk '/oom_kill/{print "OOM Events:        "$2}' /proc/vmstat >> $WORKSPACE/$REPORT_FILE

                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "=== BEFORE STRESS HOST CPU ===" >> $WORKSPACE/$REPORT_FILE
                    mpstat 1 1 | awk '/Average/{print "CPU Utilisation:   " sprintf("%.1f", 100-$NF) "%"; print "CPU Steal Time:    " sprintf("%.1f", $9) "%"; print "I/O Waits:         " sprintf("%.1f", $6) "%"}' >> $WORKSPACE/$REPORT_FILE

                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "=== BEFORE STRESS HOST DISK ===" >> $WORKSPACE/$REPORT_FILE
                    iostat -x 1 1 | awk '/^nvme/{print "I/O Throughput:    " sprintf("%.2f", ($3+$9)/1024) " MB/s"; print "Disk IOPS:         " sprintf("%.1f", $2+$8) "/sec"; print "Disk Latency:      " sprintf("%.2f", $6) " ms"}' >> $WORKSPACE/$REPORT_FILE

                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "=== BEFORE STRESS VMs ===" >> $WORKSPACE/$REPORT_FILE
                    cd $VAGRANT_DIR
                    cat > /tmp/vm_stats.sh << 'EOF'
#!/bin/bash
CPU=$(awk '/^cpu /{u=($2+$4)*100/($2+$4+$5)} END{printf "%.1f", u}' /proc/stat)
RAM=$(free -m | awk 'NR==2{printf "%.1f", ($3/$2)*100}')
STEAL=$(awk '/^cpu /{printf "%.1f", $9/($2+$3+$4+$5+$6+$7+$8+$9+$10)*100}' /proc/stat)
DISKIO=$(iostat -d -m 1 2 2>/dev/null | grep -E "vda|sda|nvme" | tail -1 | awk '{printf "%.2f", $3+$4}')
[ -z "$CPU" ] && CPU=0
[ -z "$RAM" ] && RAM=0
[ -z "$STEAL" ] && STEAL=0
[ -z "$DISKIO" ] && DISKIO=0.00
echo "vCPU %:     ${CPU}%"
echo "RAM %:      ${RAM}%"
echo "Steal Time: ${STEAL}%"
echo "Disk I/O:   ${DISKIO} MB/s"
EOF
                    chmod +x /tmp/vm_stats.sh
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- $VM ---" >> $WORKSPACE/$REPORT_FILE
                        vagrant ssh $VM -c "bash -s" < /tmp/vm_stats.sh 2>/dev/null | grep -v fog | grep -v WARNING >> $WORKSPACE/$REPORT_FILE || true
                        echo "" >> $WORKSPACE/$REPORT_FILE
                    done
                    rm -f /tmp/vm_stats.sh

                    cat $WORKSPACE/$REPORT_FILE
                '''
            }
        }

        stage('Stress') {
            steps {
                sh '''
                    echo "" >> $REPORT_FILE
                    echo "=== STRESS TEST ===" >> $REPORT_FILE
                    echo "Duration: ${TEST_DURATION}s" >> $REPORT_FILE
                    echo "Started: $(date)" >> $REPORT_FILE

                    cd $VAGRANT_DIR

                    cat > /tmp/run_stress.sh << 'EOF'
#!/bin/bash
which stress-ng >/dev/null 2>&1 || sudo apt-get install -y stress-ng -q 2>/dev/null || true
which stress-ng >/dev/null 2>&1 && sudo stress-ng --cpu 2 --vm 1 --vm-bytes 256M --timeout 30s --quiet 2>/dev/null &
echo "Stress started on $(hostname)"
EOF
                    chmod +x /tmp/run_stress.sh

                    echo "Starting stress on all VMs..."
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh $VM -c "bash -s" < /tmp/run_stress.sh 2>/dev/null | grep -v fog | grep -v WARNING || true
                        echo "PASS: Stress started on $VM" >> $REPORT_FILE
                    done
                    rm -f /tmp/run_stress.sh

                    echo "Stress running for ${TEST_DURATION}s..."
                    sleep 30

                    echo "" >> $REPORT_FILE
                    echo "=== DURING STRESS HOST ===" >> $REPORT_FILE
                    free -m | awk 'NR==2{print "RAM During Stress: " sprintf("%.1f", ($3/$2)*100) "%"}' >> $REPORT_FILE
                    mpstat 1 1 | awk '/Average/{print "CPU During Stress: " sprintf("%.1f", 100-$NF) "%"}' >> $REPORT_FILE

                    echo "Stress phase complete" >> $REPORT_FILE
                    echo "Stress phase complete"
                '''
            }
        }

        stage('After') {
            steps {
                echo ' Recording stats after stress'
                sh '''
                    echo "" >> $REPORT_FILE
                    echo "=== AFTER STRESS HOST ===" >> $REPORT_FILE
                    free -m | awk 'NR==2{print "Total RAM After:   " sprintf("%.1f", ($3/$2)*100) "%"}' >> $REPORT_FILE
                    mpstat 1 1 | awk '/Average/{print "CPU After Stress:  " sprintf("%.1f", 100-$NF) "%"}' >> $REPORT_FILE

                    echo "" >> $REPORT_FILE
                    echo "=== AFTER STRESS VMs ===" >> $REPORT_FILE
                    cd $VAGRANT_DIR
                    cat > /tmp/vm_stats.sh << 'EOF'
#!/bin/bash
CPU=$(awk '/^cpu /{u=($2+$4)*100/($2+$4+$5)} END{printf "%.1f", u}' /proc/stat)
RAM=$(free -m | awk 'NR==2{printf "%.1f", ($3/$2)*100}')
[ -z "$CPU" ] && CPU=0
[ -z "$RAM" ] && RAM=0
echo "vCPU %:     ${CPU}%"
echo "RAM %:      ${RAM}%"
EOF
                    chmod +x /tmp/vm_stats.sh
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- $VM ---" >> $WORKSPACE/$REPORT_FILE
                        vagrant ssh $VM -c "bash -s" < /tmp/vm_stats.sh 2>/dev/null | grep -v fog | grep -v WARNING >> $WORKSPACE/$REPORT_FILE || true
                        echo "" >> $WORKSPACE/$REPORT_FILE
                    done
                    rm -f /tmp/vm_stats.sh

                    echo "After snapshot complete"
                '''
            }
        }

        stage('Recovery') {
            steps {
                sh '''
                    echo "" >> $REPORT_FILE
                    echo "=== RECOVERY CHECK ===" >> $REPORT_FILE

                    sleep 10

                    TOTAL=$(kubectl --kubeconfig=$KUBECONFIG get pods --all-namespaces --no-headers 2>/dev/null | wc -l)
                    RUNNING=$(kubectl --kubeconfig=$KUBECONFIG get pods --all-namespaces --no-headers 2>/dev/null | grep -c Running || echo 0)
                    echo "Total pods: $TOTAL" >> $REPORT_FILE
                    echo "Running pods: $RUNNING" >> $REPORT_FILE

                    if [ "$RUNNING" -gt "0" ]; then
                        echo "PASS: Cluster recovered $RUNNING pods running" >> $REPORT_FILE
                        echo "PASS: Cluster recovered $RUNNING pods running"
                    else
                        echo "WARN: No running pods detected after stress" >> $REPORT_FILE
                    fi

                    free -m | awk 'NR==2{print "RAM After Recovery: " sprintf("%.1f", ($3/$2)*100) "%"}' >> $REPORT_FILE

                    echo "" >> $REPORT_FILE
                    echo "=== STRESS TEST COMPLETE: $(date) ===" >> $REPORT_FILE

                    echo ""
                    echo "STRESS TEST REPORT"
                    cat $WORKSPACE/$REPORT_FILE
                '''
                archiveArtifacts artifacts: 'stats-stress-report.txt', fingerprint: true
            }
        }
    }

    post {
        always {
            sh '''
                cd /home/ruairi/fyp-cluster
                for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                    vagrant ssh $VM -c "sudo pkill -f stress-ng 2>/dev/null || true; sudo pkill -f stress 2>/dev/null || true; rm -f /tmp/stress.log" 2>/dev/null || true
                done
                wait
                echo "All VMs cleaned up"
            '''
        }
        success { echo 'Stress test complete check stats-stress-report.txt in artifacts' }
        failure { echo 'Stress test failed all stress processes cleaned up' }
    }
}
