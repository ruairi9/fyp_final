pipeline {
    agent { label 'host-agent' }

    environment {
        KUBECONFIG    = '/home/ruairi/fyp-cluster/k3s.yaml'
        VAGRANT_DIR   = '/home/ruairi/fyp-cluster'
        REPORT_FILE   = 'application-test-report.txt'
        DEV_URL       = 'http://192.168.121.20:30081'
        PROD_URL      = 'http://192.168.121.30:30082'
        FRONTEND_URL  = 'http://192.168.121.162:30091'
    }

    stages {

        stage('Build') {
            steps {
                sh '''
                    echo "Application Load Test $(date)" > $WORKSPACE/$REPORT_FILE

                    kubectl --kubeconfig=$KUBECONFIG get pods --all-namespaces --no-headers | tee -a $WORKSPACE/$REPORT_FILE

                    RUNNING=$(kubectl --kubeconfig=$KUBECONFIG get pods --all-namespaces --no-headers | grep -c Running || echo 0)
                    if [ "$RUNNING" -lt "18" ]; then
                        echo "ABORT: only $RUNNING pods running, cluster not ready"
                        exit 1
                    fi
                    echo "$RUNNING pods running - good to go"

                    which k6 > /dev/null 2>&1 || \
                        (curl -s https://dl.k6.io/key.gpg | sudo gpg --dearmor -o /usr/share/keyrings/k6-archive-keyring.gpg 2>/dev/null && \
                        echo "deb [signed-by=/usr/share/keyrings/k6-archive-keyring.gpg] https://dl.k6.io/deb stable main" | sudo tee /etc/apt/sources.list.d/k6.list > /dev/null && \
                        sudo apt-get update -qq && sudo apt-get install -y k6 -qq 2>/dev/null) || true
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "--- Baseline ---" >> $WORKSPACE/$REPORT_FILE

                    for URL in $DEV_URL $PROD_URL; do
                        STATUS=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 $URL 2>/dev/null || echo "DOWN")
                        LATENCY=$(curl -s -o /dev/null -w "%{time_total}" --connect-timeout 5 $URL 2>/dev/null || echo "N/A")
                        echo "$URL -> $STATUS (${LATENCY}s)" | tee -a $WORKSPACE/$REPORT_FILE
                    done

                    cd $VAGRANT_DIR
                    FSTATUS=$(vagrant ssh worker-dev -c "curl -s -o /dev/null -w '%{http_code}' http://localhost:30091" 2>/dev/null | grep -v fog | grep -v WARNING | tail -1)
                    echo "frontend (internal) -> $FSTATUS" | tee -a $WORKSPACE/$REPORT_FILE

                    kubectl --kubeconfig=$KUBECONFIG top nodes 2>/dev/null >> $WORKSPACE/$REPORT_FILE || true
                '''
            }
        }

        stage('Staging') {
            steps {
                sh '''
                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "--- Load Test (50k req/service) ---" >> $WORKSPACE/$REPORT_FILE

                    for URL in $DEV_URL $PROD_URL; do
                        rm -f /tmp/success_count /tmp/fail_count
                        > /tmp/success_count; > /tmp/fail_count
                        START=$(date +%s%N)

                        for batch in $(seq 1 500); do
                            for j in $(seq 1 100); do
                                (CODE=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 3 --max-time 5 $URL 2>/dev/null || echo "000")
                                if [ "$CODE" = "200" ] || [ "$CODE" = "301" ] || [ "$CODE" = "302" ]; then
                                    echo 1 >> /tmp/success_count
                                else
                                    echo 1 >> /tmp/fail_count
                                fi) &
                            done
                            wait
                        done

                        OK=$(wc -l < /tmp/success_count 2>/dev/null || echo 0)
                        FAIL=$(wc -l < /tmp/fail_count 2>/dev/null || echo 0)
                        END=$(date +%s%N)
                        DURATION=$(echo "scale=2; ($END - $START) / 1000000000" | bc)
                        RPS=$(echo "scale=0; 50000 / $DURATION" | bc 2>/dev/null || echo "?")

                        echo "$URL: ${OK} ok, ${FAIL} failed, ${DURATION}s, ~${RPS} req/s" | tee -a $WORKSPACE/$REPORT_FILE
                    done

                    cd $VAGRANT_DIR
                    vagrant ssh worker-dev -c '
                        rm -f /tmp/success_fe /tmp/fail_fe; > /tmp/success_fe; > /tmp/fail_fe
                        for batch in $(seq 1 500); do
                            for j in $(seq 1 100); do
                                (CODE=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 3 http://localhost:30091 2>/dev/null || echo 000)
                                if [ "$CODE" = "200" ]; then echo 1 >> /tmp/success_fe; else echo 1 >> /tmp/fail_fe; fi) &
                            done
                            wait
                        done
                        OK=$(wc -l < /tmp/success_fe || echo 0)
                        FAIL=$(wc -l < /tmp/fail_fe || echo 0)
                        echo "frontend: ${OK} ok, ${FAIL} failed"
                    ' 2>/dev/null | grep -v fog | grep -v WARNING >> $WORKSPACE/$REPORT_FILE || true
                '''
            }
        }

        stage('Load') {
            steps {
                sh '''
                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "--- Spike Test ---" >> $WORKSPACE/$REPORT_FILE

                    for URL in $DEV_URL $PROD_URL; do
                        for i in $(seq 1 2000); do
                            curl -s -o /dev/null --connect-timeout 2 --max-time 3 $URL &
                        done
                    done
                    wait

                    echo "Spike done, checking pod restarts..." | tee -a $WORKSPACE/$REPORT_FILE
                    kubectl --kubeconfig=$KUBECONFIG get pods --all-namespaces \
                        --sort-by='.status.containerStatuses[0].restartCount' 2>/dev/null >> $WORKSPACE/$REPORT_FILE

                    POD=$(kubectl --kubeconfig=$KUBECONFIG get pods -n development --no-headers 2>/dev/null | head -1 | awk '{print $1}')
                    if [ -n "$POD" ]; then
                        echo "Deleting $POD to test self-healing..." | tee -a $WORKSPACE/$REPORT_FILE
                        kubectl --kubeconfig=$KUBECONFIG delete pod $POD -n development 2>/dev/null
                        sleep 15
                        RECOVERED=$(kubectl --kubeconfig=$KUBECONFIG get pods -n development --no-headers | grep -c Running || echo 0)
                        echo "Pods running after delete: $RECOVERED" | tee -a $WORKSPACE/$REPORT_FILE
                    fi
                '''
            }
        }

        stage('Production') {
            steps {
                sh '''
                    sleep 10
                    echo "" >> $WORKSPACE/$REPORT_FILE
                    echo "--- Post-test state ---" >> $WORKSPACE/$REPORT_FILE

                    RUNNING=$(kubectl --kubeconfig=$KUBECONFIG get pods --all-namespaces --no-headers | grep -c Running || echo 0)
                    echo "Running pods: $RUNNING" | tee -a $WORKSPACE/$REPORT_FILE

                    for URL in $DEV_URL $PROD_URL; do
                        STATUS=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 $URL 2>/dev/null || echo "DOWN")
                        echo "$URL -> $STATUS" | tee -a $WORKSPACE/$REPORT_FILE
                    done

                    echo "---" >> $WORKSPACE/$REPORT_FILE
                    echo "Done $(date)" >> $WORKSPACE/$REPORT_FILE
                    cat $WORKSPACE/$REPORT_FILE
                '''
                archiveArtifacts artifacts: 'application-test-report.txt', fingerprint: true
            }
        }
    }

    post {
        success { echo 'Load test passed' }
        failure { echo 'Load test failed - check report' }
    }
}
