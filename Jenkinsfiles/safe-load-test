pipeline {
    agent { label 'host-agent' }

    environment {
        VAGRANT_DIR   = '/home/ruairi/fyp-cluster'
        KUBECONFIG    = '/home/ruairi/fyp-cluster/k3s.yaml'
        REPORT_FILE   = 'load-test-report.txt'
        SAFETY_CPU    = '85'
        SAFETY_RAM    = '85'
        TEST_DURATION = '30'
    }

    stages {

        stage('Build') {
            steps {
                echo '============================================'
                echo ' SDOS SAFE LOAD TEST All 5 VMs'
                echo ' Target: 70% CPU + 70% RAM'
                echo ' Safety cut-off: CPU>85% or RAM>85%'
                echo '============================================'
                sh """
                    echo "Safe Load Test Started: \$(date)" > \$WORKSPACE/\$REPORT_FILE
                    echo "Target Load: 70% CPU, 70% RAM" >> \$WORKSPACE/\$REPORT_FILE
                    echo "Safety Cut-off: CPU<\${SAFETY_CPU}%, RAM<\${SAFETY_RAM}%" >> \$WORKSPACE/\$REPORT_FILE
                    echo "Duration: \${TEST_DURATION}s per stage" >> \$WORKSPACE/\$REPORT_FILE
                    echo "============================================" >> \$WORKSPACE/\$REPORT_FILE

                    cat > /tmp/vm_metrics.sh << 'METRICS'
#!/bin/bash
echo "CPU:  \$(top -bn2 | grep "%Cpu" | tail -1)"
echo "RAM:  \$(free -m | grep Mem | awk '{printf "%.1f%% (%dMB of %dMB)", \$3/\$2*100, \$3, \$2}')"
echo "Swap: \$(free -m | grep Swap | awk '{printf "%dMB used of %dMB (%.1f%%)", \$3, \$2, (\$2>0 ? \$3/\$2*100 : 0)}')"
echo "Load: \$(cat /proc/loadavg | cut -d' ' -f1,2,3)"
echo "Vmstat si/so: \$(vmstat 1 2 | tail -1 | awk '{print "si="\$7" so="\$8}')"
METRICS
                    chmod +x /tmp/vm_metrics.sh

                    cd \$VAGRANT_DIR

                    echo "" >> \$WORKSPACE/\$REPORT_FILE
                    echo "=== PRE-FLIGHT CHECKS ===" >> \$WORKSPACE/\$REPORT_FILE
                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        STATUS=\$(vagrant ssh \$VM -c "echo OK" 2>/dev/null | grep OK || echo "UNREACHABLE")
                        echo "\$VM: \$STATUS" >> \$WORKSPACE/\$REPORT_FILE
                        echo "\$VM: \$STATUS"
                        RAM=\$(vagrant ssh \$VM -c "bash -s" < /tmp/vm_metrics.sh 2>/dev/null | grep "RAM:" | awk '{print \$2}' | tr -d '%' | cut -d. -f1 || echo "0")
                        if [ "\$RAM" -gt "70" ] 2>/dev/null; then
                            echo "ABORT: \$VM RAM at \${RAM}% too high" >> \$WORKSPACE/\$REPORT_FILE
                            exit 1
                        fi
                        echo "\$VM pre-check RAM: \${RAM}% OK" >> \$WORKSPACE/\$REPORT_FILE
                    done

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh \$VM -c "which stress-ng > /dev/null 2>&1 || sudo apt-get install -y stress-ng -qq > /dev/null 2>&1" 2>/dev/null &
                    done
                    wait
                    echo "All VMs ready"
                """
            }
        }

        stage('Test') {
            steps {
                echo 'Stage 2 Baseline + CPU stress 80%'
                sh """
                    cd \$VAGRANT_DIR
                    echo "" >> \$WORKSPACE/\$REPORT_FILE
                    echo "=== BASELINE METRICS (per VM) ===" >> \$WORKSPACE/\$REPORT_FILE

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- \$VM ---" >> \$WORKSPACE/\$REPORT_FILE
                        vagrant ssh \$VM -c "bash -s" < /tmp/vm_metrics.sh 2>/dev/null | grep -v fog | grep -v WARNING >> \$WORKSPACE/\$REPORT_FILE || true
                        echo "" >> \$WORKSPACE/\$REPORT_FILE
                    done

                    echo "" >> \$WORKSPACE/\$REPORT_FILE
                    echo "=== CPU STRESS 70% (per VM) ===" >> \$WORKSPACE/\$REPORT_FILE

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh \$VM -c "printf '#!/bin/sh\\nstress-ng --cpu 1 --cpu-load 5 --timeout 90s > /tmp/stress.log 2>&1\\n' > /tmp/run_stress.sh; chmod +x /tmp/run_stress.sh; nohup /tmp/run_stress.sh > /dev/null 2>&1 &" 2>/dev/null
                    done
                    echo "CPU stress started on all VMs - waiting 40s for peak..."
                    sleep 40

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh \$VM -c "bash -s" < /tmp/vm_metrics.sh 2>/dev/null | grep -v fog | grep -v WARNING > /tmp/cpu_peak_\${VM}.txt &
                    done
                    wait

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- \$VM CPU peak ---" >> \$WORKSPACE/\$REPORT_FILE
                        cat /tmp/cpu_peak_\${VM}.txt >> \$WORKSPACE/\$REPORT_FILE 2>/dev/null || true
                        echo "" >> \$WORKSPACE/\$REPORT_FILE
                    done
                    sleep 45
                """
            }
        }

        stage('Staging') {
            steps {
                echo 'Stage 3 RAM stress 75%'
                sh """
                    cd \$VAGRANT_DIR
                    echo "" >> \$WORKSPACE/\$REPORT_FILE
                    echo "=== RAM STRESS 70% (per VM) ===" >> \$WORKSPACE/\$REPORT_FILE

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh \$VM -c "printf '#!/bin/sh\\nstress-ng --vm 1 --vm-bytes 40%% --vm-keep --timeout 90s > /tmp/stress.log 2>&1\\n' > /tmp/run_stress.sh; chmod +x /tmp/run_stress.sh; nohup /tmp/run_stress.sh > /dev/null 2>&1 &" 2>/dev/null
                    done
                    echo "RAM stress started on all VMs - waiting 40s for peak..."
                    sleep 40

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh \$VM -c "bash -s" < /tmp/vm_metrics.sh 2>/dev/null | grep -v fog | grep -v WARNING > /tmp/ram_peak_\${VM}.txt &
                    done
                    wait

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- \$VM RAM peak ---" >> \$WORKSPACE/\$REPORT_FILE
                        cat /tmp/ram_peak_\${VM}.txt >> \$WORKSPACE/\$REPORT_FILE 2>/dev/null || true
                        vagrant ssh \$VM -c "grep SwapFree /proc/meminfo; grep SwapTotal /proc/meminfo" 2>/dev/null | grep -v fog >> \$WORKSPACE/\$REPORT_FILE || true
                        echo "" >> \$WORKSPACE/\$REPORT_FILE
                    done
                    sleep 45
                """
            }
        }

        stage('Load') {
            steps {
                echo 'Stage 4 Combined 80% CPU + 70% RAM'
                sh """
                    cd \$VAGRANT_DIR
                    echo "" >> \$WORKSPACE/\$REPORT_FILE
                    echo "=== COMBINED STRESS 70% CPU + 65% RAM (per VM) ===" >> \$WORKSPACE/\$REPORT_FILE

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh \$VM -c "printf '#!/bin/sh\\nstress-ng --cpu 1 --cpu-load 5 --vm 1 --vm-bytes 40%% --vm-keep --timeout 90s > /tmp/stress.log 2>&1\\n' > /tmp/run_stress.sh; chmod +x /tmp/run_stress.sh; nohup /tmp/run_stress.sh > /dev/null 2>&1 &" 2>/dev/null
                    done
                    echo "Combined stress started on all VMs - waiting 40s for peak..."
                    sleep 40

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh \$VM -c "bash -s" < /tmp/vm_metrics.sh 2>/dev/null | grep -v fog | grep -v WARNING > /tmp/combined_peak_\${VM}.txt &
                    done
                    wait

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- \$VM combined peak ---" >> \$WORKSPACE/\$REPORT_FILE
                        cat /tmp/combined_peak_\${VM}.txt >> \$WORKSPACE/\$REPORT_FILE 2>/dev/null || true
                        echo "" >> \$WORKSPACE/\$REPORT_FILE
                    done
                    sleep 45
                """
            }
        }

        stage('Production') {
            steps {
                echo 'Stage 5 Cleanup and Recovery'
                sh """
                    cd \$VAGRANT_DIR

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        vagrant ssh \$VM -c "
                            sudo pkill -9 -f stress-ng 2>/dev/null; true
                            sudo rm -f /tmp/stress* /tmp/run_stress*
                            sudo sync
                            echo 3 | sudo tee /proc/sys/vm/drop_caches > /dev/null
                            sudo journalctl --vacuum-size=100M 2>/dev/null
                            sudo truncate -s 0 /var/log/auth.log 2>/dev/null
                            sudo truncate -s 0 /var/log/syslog 2>/dev/null
                            sudo fstrim -v / 2>/dev/null
                        " 2>/dev/null &
                    done
                    wait
                    sleep 20

                    echo "" >> \$WORKSPACE/\$REPORT_FILE
                    echo "=== POST-STRESS RECOVERY (per VM) ===" >> \$WORKSPACE/\$REPORT_FILE

                    for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                        echo "--- \$VM ---" >> \$WORKSPACE/\$REPORT_FILE
                        vagrant ssh \$VM -c "bash -s" < /tmp/vm_metrics.sh 2>/dev/null | grep -v fog | grep -v WARNING >> \$WORKSPACE/\$REPORT_FILE || true
                        echo "" >> \$WORKSPACE/\$REPORT_FILE
                    done

                    TOTAL=\$(kubectl --kubeconfig=\$KUBECONFIG get pods --all-namespaces --no-headers 2>/dev/null | wc -l)
                    RUNNING=\$(kubectl --kubeconfig=\$KUBECONFIG get pods --all-namespaces --no-headers 2>/dev/null | grep -c Running || echo 0)
                    echo "" >> \$WORKSPACE/\$REPORT_FILE
                    echo "=== CLUSTER HEALTH AFTER STRESS ===" >> \$WORKSPACE/\$REPORT_FILE
                    echo "Total pods: \$TOTAL" >> \$WORKSPACE/\$REPORT_FILE
                    echo "Running pods: \$RUNNING" >> \$WORKSPACE/\$REPORT_FILE

                    if [ "\$RUNNING" -gt "18" ]; then
                        echo "PASS: Cluster healthy \$RUNNING pods running" >> \$WORKSPACE/\$REPORT_FILE
                        echo "PASS: Cluster healthy \$RUNNING pods running"
                    else
                        echo "WARN: Only \$RUNNING pods running after stress!" >> \$WORKSPACE/\$REPORT_FILE
                    fi

                    echo "" >> \$WORKSPACE/\$REPORT_FILE
                    echo "=== TEST COMPLETE: \$(date) ===" >> \$WORKSPACE/\$REPORT_FILE

                    cat \$WORKSPACE/\$REPORT_FILE
                """
                archiveArtifacts artifacts: 'load-test-report.txt', fingerprint: true
            }
        }
    }

    post {
        always {
            sh """
                cd /home/ruairi/fyp-cluster 2>/dev/null || true
                for VM in control-plane worker-dev worker-prod worker-cicd worker-monitoring; do
                    vagrant ssh \$VM -c "sudo pkill -9 -f stress-ng 2>/dev/null || true; rm -f /tmp/stress.log /tmp/vm_metrics.sh" 2>/dev/null &
                done
                wait
                echo "All VMs cleaned up"
            """
        }
        success { echo 'Safe load test completed check load-test-report.txt' }
        failure { echo 'Safe load test failed all stress processes cleaned up' }
    }
}
