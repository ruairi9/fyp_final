pipeline {
    agent { label 'host-agent' }

    environment {
        KUBECONFIG  = '/home/ruairi/fyp-cluster/k3s.yaml'
        REGISTRY    = '192.168.121.50:30500'
        REPORT_FILE = 'security-scan-report.txt'
    }

    stages {

        stage('Setup') {
            steps {
                sh '''
                    echo "Security Scan $(date)" > $REPORT_FILE
                    export PATH=$PATH:/home/ruairi/.local/bin
                    if ! which trivy > /dev/null 2>&1; then
                        echo "Installing trivy..."
                        mkdir -p /home/ruairi/.local/bin
                        curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /home/ruairi/.local/bin
                    fi
                    trivy --version
                '''
            }
        }

        stage('Scan Images') {
            steps {
                sh '''
                    export PATH=$PATH:/home/ruairi/.local/bin
                    echo "" >> $REPORT_FILE

                    for IMG in nginx:1.25.3 python:3.11-alpine; do
                        echo "Scanning $IMG..."
                        echo "--- $IMG ---" >> $REPORT_FILE
                        trivy image --severity HIGH,CRITICAL --no-progress $IMG 2>/dev/null >> $REPORT_FILE || true
                        echo "" >> $REPORT_FILE
                    done

                    echo "Scanning sdos-backend..."
                    echo "--- sdos-backend ---" >> $REPORT_FILE
                    trivy image --severity HIGH,CRITICAL --no-progress --insecure \
                        $REGISTRY/sdos-backend:latest 2>/dev/null >> $REPORT_FILE \
                        || echo "not in registry, skipping" >> $REPORT_FILE
                '''
            }
        }

        stage('Scan K8s') {
            steps {
                sh '''
                    export PATH=$PATH:/home/ruairi/.local/bin
                    echo "" >> $REPORT_FILE
                    echo "--- cluster scan ---" >> $REPORT_FILE
                    trivy k8s --severity HIGH,CRITICAL --no-progress \
                        --kubeconfig $KUBECONFIG --report summary \
                        cluster 2>/dev/null >> $REPORT_FILE || true

                    echo "" >> $REPORT_FILE
                    echo "--- config files ---" >> $REPORT_FILE
                    cd /home/ruairi/fyp-cluster
                    [ -f "Dockerfile" ] && trivy config --severity HIGH,CRITICAL --no-progress Dockerfile 2>/dev/null >> $WORKSPACE/$REPORT_FILE || true
                    find . -name "*.yaml" -not -path "*/.*" 2>/dev/null | head -5 | while read f; do
                        trivy config --severity HIGH,CRITICAL --no-progress "$f" 2>/dev/null >> $WORKSPACE/$REPORT_FILE || true
                    done
                '''
            }
        }


        stage('Scan Config') {
            steps {
                sh '''
                    export PATH=$PATH:/home/ruairi/.local/bin
                    echo "" >> $REPORT_FILE
                    echo "=== CONFIG FILE SCANS ===" >> $REPORT_FILE

                    cd /home/ruairi/fyp-cluster

                    if [ -f "Dockerfile" ]; then
                        echo "--- Dockerfile ---" >> $WORKSPACE/$REPORT_FILE
                        trivy config --severity HIGH,CRITICAL --no-progress Dockerfile 2>/dev/null >> $WORKSPACE/$REPORT_FILE || true
                    fi

                    echo "--- K8s Manifests ---" >> $WORKSPACE/$REPORT_FILE
                    find . -name "*.yaml" -not -path "*/.*" 2>/dev/null | head -10 | while read f; do
                        echo "Scanning $f..." >> $WORKSPACE/$REPORT_FILE
                        trivy config --severity HIGH,CRITICAL --no-progress "$f" 2>/dev/null >> $WORKSPACE/$REPORT_FILE || true
                    done

                    echo "Config scan complete"
                '''
            }
        }
        stage('Report') {
            steps {
                sh '''
                    CRITICAL=$(grep -c "CRITICAL" $REPORT_FILE || echo 0)
                    HIGH=$(grep -c "HIGH" $REPORT_FILE || echo 0)
                    echo "" >> $REPORT_FILE
                    echo "CRITICAL: $CRITICAL, HIGH: $HIGH" >> $REPORT_FILE
                    echo "Done $(date)" >> $REPORT_FILE

                    echo "Results: $CRITICAL critical, $HIGH high"
                    echo "(full report in artifacts)"
                '''
                archiveArtifacts artifacts: 'security-scan-report.txt', fingerprint: true
            }
        }
    }

    post {
        success { echo 'Scan done - check report' }
        failure { echo 'Scan failed' }
    }
}
